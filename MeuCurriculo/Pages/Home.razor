@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://avatars.githubusercontent.com/u/260698427?v=4" class="rounded-circle mb-3"
                     width="120" />
                <h3>Luis Coelho</h3>
                <p class="text-muted">Desenvolvedor Web</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "UNA - Barreiro",
            Cargo = "Graduando em Ciência da Computação",
            Inicio = "2026",
            Descricao = "Desenvolvimento de sólida base teórica e prática em algoritmos, estrutura de dados e engenharia de software em nível superior."
        },
        new Experiencia {
            Empresa = "SENAI Euvaldo Lodi",
            Cargo = "Técnico em Informática para Internet",
            Inicio = "2020", Fim = "2021",
            Descricao = "Formação técnica profissionalizante com foco em desenvolvimento web, redes e suporte, consolidando os primeiros passos na área de tecnologia."
        }
    };
}